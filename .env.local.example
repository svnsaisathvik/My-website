# Copy this file to .env.local and fill in your real values.
# .env.local is already gitignored — never commit real credentials.

# MongoDB Atlas connection string.
# In Atlas: Database > Connect > Drivers, copy the srv connection string,
# then replace <username>/<password>/<dbname> with your own.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Logical database name inside the cluster (created automatically on first write).
MONGODB_DB=portfolio
